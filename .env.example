# Copia este archivo como .env y rellena tus valores
# (o pon los valores directamente en config.py)

PRIVATE_KEY=0x...
POLYMARKET_API_KEY=...
POLYMARKET_SECRET=...
POLYMARKET_PASSPHRASE=...

# RPC de Polygon para leer Chainlink directamente (precio oficial de resolución)
# Obtén uno gratis en https://www.alchemy.com → Create App → Polygon PoS Mainnet
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/TU_API_KEY

DRY_RUN=true
